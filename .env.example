# ---------------------------------------------------------------------------
# FundXRay — environment template
# Copy to .env and fill in. NEVER commit .env.
# ---------------------------------------------------------------------------

# --- Groq (LLM enrichment: plain-language explanations + parser fallback) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Angel One SmartAPI -----------------------------------------------------
# https://smartapi.angelbroking.com/
SMARTAPI_API_KEY=
SMARTAPI_CLIENT_ID=
SMARTAPI_PASSWORD=
SMARTAPI_TOTP_SECRET=
# Throttle (requests/second) — stay under Angel One's published rate limits
SMARTAPI_RATE_LIMIT_RPS=3
SMARTAPI_HISTORICAL_RATE_LIMIT_RPS=1

# --- Object storage (MinIO locally, R2/S3 in prod) --------------------------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_WAREHOUSE=fundxray-warehouse
S3_BUCKET_ARTIFACTS=fundxray-artifacts

# --- Hive Metastore / Iceberg catalog ---------------------------------------
HIVE_METASTORE_URI=thrift://localhost:9083
ICEBERG_CATALOG_NAME=fundxray
ICEBERG_WAREHOUSE=s3a://fundxray-warehouse/

# --- Spark ------------------------------------------------------------------
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g
SPARK_SQL_SHUFFLE_PARTITIONS=200

# --- Kafka ------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TICKS=marketdata.ticks
KAFKA_TOPIC_DLQ=marketdata.dlq

# --- Postgres (app metadata, not the warehouse) -----------------------------
POSTGRES_DSN=postgresql://fundxray:fundxray@localhost:5432/fundxray

# --- Serving ----------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
ARTIFACT_PATH=data/artifacts/fundxray.duckdb
ARTIFACT_REFRESH_CRON=0 2 * * *

# --- Data quality -----------------------------------------------------------
# Max acceptable variance when reconciling parsed holdings against reported AUM
RECONCILIATION_TOLERANCE_PCT=0.5
# Freshness SLAs (hours)
SLA_NAV_HOURS=24
SLA_DISCLOSURE_HOURS=720

# --- assumptions ---
DTL_PARTICIPATION_RATE=0.20
DATA_DIR=data
